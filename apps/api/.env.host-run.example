# Backend settings for host-run local development.

DEBUG=1
ALLOWED_HOSTS="127.0.0.1,localhost"
CORS_ALLOWED_ORIGINS="http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,http://127.0.0.1:3100,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3100"

DATABASE_URL="postgresql://plane:plane@127.0.0.1:5432/plane"
REDIS_URL="redis://127.0.0.1:6379/"
AMQP_URL="amqp://plane:plane@127.0.0.1:5672/plane"

AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_ENDPOINT_URL=""
AWS_S3_BUCKET_NAME=""
SIGNED_URL_EXPIRATION=3600
FILE_SIZE_LIMIT=5242880
USE_MINIO=0
MINIO_ENDPOINT_SSL=0

WEB_URL="http://127.0.0.1:8000"
APP_BASE_URL="http://127.0.0.1:3000"
APP_BASE_PATH=""
ADMIN_BASE_URL="http://127.0.0.1:3001"
ADMIN_BASE_PATH="/god-mode"
SPACE_BASE_URL="http://127.0.0.1:3002"
SPACE_BASE_PATH="/spaces"
LIVE_BASE_URL="http://127.0.0.1:3100"
LIVE_BASE_PATH="/live"
LIVE_SERVER_SECRET_KEY="secret-key"

GUNICORN_WORKERS=2
HARD_DELETE_AFTER_DAYS=60
API_KEY_RATE_LIMIT="60/minute"

# Added by `make dev-env` if it is missing:
# SECRET_KEY="..."
