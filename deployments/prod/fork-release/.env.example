# Release selection
IMAGE_TAG=v1.3.0-mw.1

# Public URLs
WEB_URL=https://plane.meetwise.ru
CORS_ALLOWED_ORIGINS=https://plane.meetwise.ru
FILE_SIZE_LIMIT=5242880

# Django / Plane application
DEBUG=0
SECRET_KEY=replace-me
API_KEY_RATE_LIMIT=60/minute
LIVE_SERVER_SECRET_KEY=replace-me

# PostgreSQL
POSTGRES_CONTAINER_NAME=plane-db
POSTGRES_USER=plane
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=plane
POSTGRES_PORT=5432
DATABASE_URL=postgresql://plane:replace-me@plane-db:5432/plane

# Redis
REDIS_CONTAINER_NAME=plane-redis
REDIS_URL=redis://plane-redis:6379/

# RabbitMQ
RABBITMQ_CONTAINER_NAME=plane-mq
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=replace-me
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:replace-me@plane-mq:5672/plane

# External S3 storage
USE_MINIO=0
MINIO_ENDPOINT_SSL=1
AWS_REGION=ru1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_ENDPOINT_URL=https://s3.ru1.storage.beget.cloud
AWS_S3_BUCKET_NAME=3683984e7e3b-plane-prod

# SMTP
EMAIL_HOST=smtp.beget.com
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
EMAIL_PORT=465
EMAIL_USE_SSL=1
DEFAULT_FROM_EMAIL=replace-me

# Proxy / ingress
LISTEN_ADDRESS=127.0.0.1
LISTEN_PORT=8090

# Operational scripts
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
SNAPSHOT_DIR=./snapshots
NGINX_VHOST_PATH=/etc/nginx/sites-available/plane
COMPOSE_FILE=./docker-compose.prod.yml
CADDY_FILE=./caddy/Caddyfile

# Optional deploy controls
COMPOSE_PROJECT_NAME=plane
