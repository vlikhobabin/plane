# Infrastructure services for local host-run development.

POSTGRES_USER="plane"
POSTGRES_PASSWORD="plane"
POSTGRES_DB="plane"
PGDATA="/var/lib/postgresql/data"

REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

RABBITMQ_HOST="127.0.0.1"
RABBITMQ_PORT="5672"
RABBITMQ_USER="plane"
RABBITMQ_PASSWORD="plane"
RABBITMQ_VHOST="plane"

# Optional external S3-compatible object storage for uploads.
# The host-run infra stack no longer starts MinIO locally.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET_NAME=""
AWS_S3_ENDPOINT_URL=""
